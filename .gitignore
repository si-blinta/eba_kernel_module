# Ignore everything
*

# But not these:
!*/                  # Do not ignore directories, so Git can traverse them.
!*.c                # Do not ignore any .c files.
!*.h                # Do not ignore any .h files.
!Makefile           # Do not ignore Makefile.
!.gitignore         # Do not ignore .gitignore itself.

# Include generated Doxygen documentation:
!docs/html/index.html  # Include the main HTML file from Doxygen.
!docs/latex/*.pdf       # Include any PDF file generated by Doxygen in the LaTeX directory.
